# Jira Service Desk MCP Server Configuration
#
# Authentication — choose ONE of the three options below.

# Option 1: Shared MCP config style (same shape as mcp-atlassian)
# JIRA_URL=https://jira.your-company.com
# JIRA_PERSONAL_TOKEN=<base64-encoded username:token>

# Option 2: Atlassian Cloud (username + API token)
# JIRA_URL=https://your-instance.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=your-api-token

# Option 3: Server / Data Center (raw Personal Access Token)
# You can use either the raw token or the full "Bearer <token>" value.
# JIRA_URL=https://jira.your-company.com
# JIRA_PERSONAL_TOKEN=<raw-pat-value>

# Optional: override cloud auto-detection (auto-detected from URL by default)
# JIRA_IS_CLOUD=false

# Optional: disable SSL verification (e.g. for self-signed certs)
# JIRA_SSL_VERIFY=false

# Optional: restrict to read-only mode
# READ_ONLY_MODE=true
